{
  "name": "openhouse-web",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "OpenHouse local-first desktop and service control shell",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.mjs",
    "check": "node scripts/check.mjs",
    "test": "node --test test/*.test.mjs",
    "build": "node scripts/build.mjs",
    "integration": "node --test test/server.integration.test.mjs",
    "test:integration": "node --test test/server.integration.test.mjs"
  }
}
